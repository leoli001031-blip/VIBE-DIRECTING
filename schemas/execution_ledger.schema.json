{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/execution_ledger.schema.json",
  "title": "ExecutionLedgerState",
  "description": "State-only execution ledger for scoped real-test intent. It records selected scope evidence without writing ledger files, spawning workers, submitting providers, reading credentials, or mutating files.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "phase",
    "ledgerId",
    "mode",
    "status",
    "projectId",
    "selectedShotIds",
    "selectedTaskPlanIds",
    "selectedEnvelopeIds",
    "outputSandbox",
    "scopeBlockers",
    "entries",
    "summary",
    "hardLocks",
    "sourceCoverage",
    "notes"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "generatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "phase": { "const": "scoped_real_execution_ledger" },
    "ledgerId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "mode": { "$ref": "#/$defs/mode" },
    "status": { "$ref": "#/$defs/status" },
    "projectId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "batchId": { "type": "string" },
    "selectedShotIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "selectedTaskPlanIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "selectedEnvelopeIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "outputSandbox": { "$ref": "#/$defs/outputSandbox" },
    "scopeBlockers": { "type": "array", "items": { "type": "string" } },
    "entries": { "type": "array", "items": { "$ref": "#/$defs/entry" } },
    "summary": { "$ref": "#/$defs/summary" },
    "hardLocks": { "$ref": "#/$defs/hardLocks" },
    "sourceCoverage": { "type": "array", "items": { "$ref": "#/$defs/sourceCoverage" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "mode": {
      "type": "string",
      "enum": ["locked", "scoped_real_test"]
    },
    "status": {
      "type": "string",
      "enum": ["locked", "blocked", "ready_for_scoped_review"]
    },
    "outputSandbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "allowedPrefixes",
        "manifestPath",
        "qaReportPath",
        "ledgerPath",
        "projectRootRelative",
        "outsideRootWriteAllowed"
      ],
      "properties": {
        "root": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "allowedPrefixes": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
        "manifestPath": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "qaReportPath": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "ledgerPath": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "projectRootRelative": { "const": true },
        "outsideRootWriteAllowed": { "const": false }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ledgerEntryId",
        "projectId",
        "taskPlanId",
        "jobId",
        "providerId",
        "providerSlot",
        "requiredMode",
        "expectedOutputs",
        "outputSandboxRoot",
        "status",
        "envelopeValid",
        "outputSandboxValid",
        "manifestStatus",
        "manifestReady",
        "qaStatus",
        "qaReady",
        "evidenceRefs",
        "blockers",
        "warnings",
        "attemptOrdinal",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "canSpawnWorker",
        "actualExecutionAllowed",
        "ledgerRecordOnly"
      ],
      "properties": {
        "ledgerEntryId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "projectId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "batchId": { "type": "string" },
        "shotId": { "type": "string" },
        "taskPlanId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "jobId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "envelopeId": { "type": "string" },
        "providerId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "providerSlot": { "$ref": "common.schema.json#/$defs/providerSlot" },
        "requiredMode": { "$ref": "common.schema.json#/$defs/requiredMode" },
        "expectedOutputs": { "type": "array", "items": { "type": "string" } },
        "outputSandboxRoot": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "status": { "$ref": "#/$defs/status" },
        "envelopeValid": { "type": "boolean" },
        "outputSandboxValid": { "type": "boolean" },
        "manifestStatus": { "type": "string" },
        "manifestReady": { "type": "boolean" },
        "qaStatus": { "type": "string" },
        "qaReady": { "type": "boolean" },
        "evidenceRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "attemptOrdinal": { "const": 0 },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "canSpawnWorker": { "const": false },
        "actualExecutionAllowed": { "const": false },
        "ledgerRecordOnly": { "const": true }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalEntries",
        "scopedEntries",
        "locked",
        "blocked",
        "readyForScopedReview",
        "actualExecutions",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialReads",
        "workerSpawns",
        "ledgerWriteAllowed"
      ],
      "properties": {
        "totalEntries": { "type": "integer", "minimum": 0 },
        "scopedEntries": { "type": "integer", "minimum": 0 },
        "locked": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "readyForScopedReview": { "type": "integer", "minimum": 0 },
        "actualExecutions": { "type": "integer", "const": 0 },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialReads": { "type": "integer", "const": 0 },
        "workerSpawns": { "type": "integer", "const": 0 },
        "ledgerWriteAllowed": { "const": false }
      }
    },
    "hardLocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultLocked",
        "stateOnly",
        "appendOnly",
        "ledgerWriteAllowed",
        "actualExecutionAllowed",
        "canSpawnWorker",
        "noWorkerSpawn",
        "noSubprocess",
        "noShellExecution",
        "providerSubmissionForbidden",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "noCredentialRead",
        "noCredentialWrite",
        "noFileMutation",
        "outsideSandboxWriteForbidden"
      ],
      "properties": {
        "defaultLocked": { "const": true },
        "stateOnly": { "const": true },
        "appendOnly": { "const": true },
        "ledgerWriteAllowed": { "const": false },
        "actualExecutionAllowed": { "const": false },
        "canSpawnWorker": { "const": false },
        "noWorkerSpawn": { "const": true },
        "noSubprocess": { "const": true },
        "noShellExecution": { "const": true },
        "providerSubmissionForbidden": { "const": true },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "noCredentialRead": { "const": true },
        "noCredentialWrite": { "const": true },
        "noFileMutation": { "const": true },
        "outsideSandboxWriteForbidden": { "const": true }
      }
    },
    "sourceCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer", "referenced", "referenceCount", "sourceRefs"],
      "properties": {
        "layer": {
          "type": "string",
          "enum": ["taskViews", "imageTaskPlans", "manifestMatches", "qaHarness", "generationHarness", "outputSandbox"]
        },
        "referenced": { "type": "boolean" },
        "referenceCount": { "type": "integer", "minimum": 0 },
        "sourceRefs": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    }
  }
}

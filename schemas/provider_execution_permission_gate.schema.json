{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/provider_execution_permission_gate.schema.json",
  "title": "ProviderExecutionPermissionGateState",
  "description": "Phase 31 final provider execution permission gate. It prepares action-time confirmation requests only and never submits providers, spawns workers, reads credentials, or mutates files.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "phase", "requests", "summary", "hardLocks", "phase31Evidence", "forbiddenActions", "notes"],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "generatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "phase": { "const": "phase_31_provider_execution_permission_gate" },
    "requests": {
      "type": "array",
      "items": { "$ref": "#/$defs/request" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalRequests",
        "readyForUserReview",
        "blocked",
        "parked",
        "canAskUserToConfirm",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "automaticSubmitAllowed"
      ],
      "properties": {
        "totalRequests": { "type": "integer", "minimum": 0 },
        "readyForUserReview": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "parked": { "type": "integer", "minimum": 0 },
        "canAskUserToConfirm": { "type": "integer", "minimum": 0 },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "automaticSubmitAllowed": { "const": false }
      }
    },
    "hardLocks": { "$ref": "#/$defs/hardLocks" },
    "phase31Evidence": { "$ref": "#/$defs/phase31Evidence" },
    "forbiddenActions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "provider_submit",
          "credential_read",
          "credential_write",
          "api_key_create",
          "arbitrary_provider_command",
          "worker_spawn",
          "file_mutation",
          "fast_model",
          "vip_channel",
          "text_to_video_main_path",
          "bgm_in_video_prompt"
        ]
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["ready_for_user_review", "blocked", "parked"]
    },
    "providerSlot": {
      "type": "string",
      "enum": [
        "image.generate",
        "image.edit",
        "image.reference_asset",
        "video.i2v",
        "video.t2v.experimental",
        "video.extend",
        "video.edit",
        "audio.tts",
        "audio.music",
        "local.postprocess",
        "local.workflow"
      ]
    },
    "requiredMode": {
      "type": "string",
      "enum": [
        "text2image",
        "image2image",
        "frames2video",
        "text2video",
        "video2video",
        "tts",
        "music",
        "postprocess",
        "import_only",
        "not_applicable"
      ]
    },
    "confirmationId": {
      "type": "string",
      "enum": [
        "review_provider_packet",
        "action_time_user_confirmation",
        "confirm_expected_outputs",
        "confirm_no_credentials",
        "confirm_no_fast_vip_t2v_bgm"
      ]
    },
    "confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmationId", "label", "required", "present", "confirmed"],
      "properties": {
        "confirmationId": { "$ref": "#/$defs/confirmationId" },
        "label": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "required": { "const": true },
        "present": { "type": "boolean" },
        "confirmed": { "type": "boolean" },
        "blocker": { "type": "string" }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestId",
        "sourceGateId",
        "sourceId",
        "providerId",
        "slot",
        "requiredMode",
        "status",
        "confirmations",
        "blockers",
        "warnings",
        "executionOrder",
        "canAskUserToConfirm",
        "actionTimeConfirmationRequired",
        "userConfirmedAtActionTime",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "credentialStorage",
        "dryRunOnly",
        "readOnly",
        "noWorkerSpawn",
        "noFileMutation"
      ],
      "properties": {
        "requestId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceGateId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "providerId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "slot": { "$ref": "#/$defs/providerSlot" },
        "requiredMode": { "$ref": "#/$defs/requiredMode" },
        "shotId": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "confirmations": {
          "type": "array",
          "items": { "$ref": "#/$defs/confirmation" }
        },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "executionOrder": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "review_provider_packet",
              "ask_action_time_confirmation",
              "record_confirmation_receipt",
              "wait_for_future_execution_gate"
            ]
          }
        },
        "canAskUserToConfirm": { "type": "boolean" },
        "actionTimeConfirmationRequired": { "const": true },
        "userConfirmedAtActionTime": { "const": false },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "credentialStorage": { "const": false },
        "dryRunOnly": { "const": true },
        "readOnly": { "const": true },
        "noWorkerSpawn": { "const": true },
        "noFileMutation": { "const": true }
      }
    },
    "hardLocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dryRunOnly",
        "readOnly",
        "reviewPlanOnly",
        "actionTimeConfirmationRequired",
        "providerSubmissionForbidden",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "credentialStorage",
        "noCredentialRead",
        "noCredentialWrite",
        "noApiKeyCreation",
        "noArbitraryProviderCommand",
        "noWorkerSpawn",
        "noFileMutation",
        "fastModelForbidden",
        "vipChannelForbidden",
        "textToVideoMainPathForbidden",
        "bgmInVideoPromptForbidden"
      ],
      "properties": {
        "dryRunOnly": { "const": true },
        "readOnly": { "const": true },
        "reviewPlanOnly": { "const": true },
        "actionTimeConfirmationRequired": { "const": true },
        "providerSubmissionForbidden": { "const": true },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "credentialStorage": { "const": false },
        "noCredentialRead": { "const": true },
        "noCredentialWrite": { "const": true },
        "noApiKeyCreation": { "const": true },
        "noArbitraryProviderCommand": { "const": true },
        "noWorkerSpawn": { "const": true },
        "noFileMutation": { "const": true },
        "fastModelForbidden": { "const": true },
        "vipChannelForbidden": { "const": true },
        "textToVideoMainPathForbidden": { "const": true },
        "bgmInVideoPromptForbidden": { "const": true }
      }
    },
    "phase31Evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phaseId",
        "typedEvidencePresent",
        "phase30GateConsumed",
        "actionTimeUserConfirmationRequired",
        "automaticSubmitForbidden",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "noWorkerSpawn",
        "noFileMutation",
        "forbiddenProviderModesAbsent"
      ],
      "properties": {
        "phaseId": { "const": "phase_31_provider_execution_permission_gate" },
        "typedEvidencePresent": { "const": true },
        "phase30GateConsumed": { "type": "boolean" },
        "actionTimeUserConfirmationRequired": { "const": true },
        "automaticSubmitForbidden": { "const": true },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "noWorkerSpawn": { "const": true },
        "noFileMutation": { "const": true },
        "forbiddenProviderModesAbsent": { "type": "boolean" }
      }
    }
  }
}

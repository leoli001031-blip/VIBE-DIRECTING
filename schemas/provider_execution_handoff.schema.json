{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/provider_execution_handoff.schema.json",
  "title": "ProviderExecutionHandoffState",
  "description": "Phase 33 Provider Execution Handoff / Final Action Gate. It consumes Phase 32 action-time confirmation receipt evidence and emits a structured handoff plan only; it never submits providers, reads credentials, spawns workers, or mutates files.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "phase", "status", "handoffs", "summary", "hardLocks", "phase33Evidence", "forbiddenActions", "notes"],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "generatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "phase": { "const": "phase_33_provider_execution_handoff" },
    "status": { "$ref": "#/$defs/status" },
    "handoffs": {
      "type": "array",
      "items": { "$ref": "#/$defs/handoff" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalHandoffs",
        "blockedMissingActionConfirmation",
        "readyForFinalUserHandoffReview",
        "blocked",
        "confirmedReceiptCountObserved",
        "userConfirmedAtActionTimeObserved",
        "canEnterFinalUserHandoffReview",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "automaticSubmitAllowed",
        "canSpawnWorker",
        "fileMutationAllowed",
        "handoffPlanOnly",
        "finalActionGateRequired"
      ],
      "properties": {
        "totalHandoffs": { "type": "integer", "minimum": 0 },
        "blockedMissingActionConfirmation": { "type": "integer", "minimum": 0 },
        "readyForFinalUserHandoffReview": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "confirmedReceiptCountObserved": { "type": "integer", "minimum": 0 },
        "userConfirmedAtActionTimeObserved": { "type": "boolean" },
        "canEnterFinalUserHandoffReview": { "type": "integer", "minimum": 0 },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "automaticSubmitAllowed": { "const": false },
        "canSpawnWorker": { "const": false },
        "fileMutationAllowed": { "const": false },
        "handoffPlanOnly": { "const": true },
        "finalActionGateRequired": { "const": true }
      }
    },
    "hardLocks": { "$ref": "#/$defs/hardLocks" },
    "phase33Evidence": { "$ref": "#/$defs/phase33Evidence" },
    "forbiddenActions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "provider_submit",
          "automatic_submit",
          "credential_read",
          "credential_write",
          "api_key_create",
          "arbitrary_provider_command",
          "worker_spawn",
          "file_mutation",
          "fast_model",
          "vip_channel",
          "text_to_video_main_path",
          "bgm_in_video_prompt"
        ]
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["blocked_missing_action_confirmation", "ready_for_final_user_handoff_review", "blocked"]
    },
    "reviewStep": {
      "type": "string",
      "enum": [
        "review_action_time_confirmation_receipt",
        "review_provider_execution_handoff_plan",
        "final_user_handoff_review",
        "hold_provider_execution"
      ]
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoffId",
        "sourceActionConfirmationRequestId",
        "sourcePermissionRequestId",
        "sourceGateId",
        "sourceId",
        "providerId",
        "slot",
        "requiredMode",
        "status",
        "blockers",
        "warnings",
        "reviewOrder",
        "receiptConfirmed",
        "userConfirmedAtActionTime",
        "confirmedReceiptCount",
        "canEnterFinalUserHandoffReview",
        "finalActionGateRequired",
        "finalUserReviewRequired",
        "handoffPlanOnly",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "automaticSubmitAllowed",
        "canSpawnWorker",
        "fileMutationAllowed",
        "dryRunOnly",
        "readOnly",
        "noProviderSubmit",
        "noCredentialRead",
        "noCredentialWrite",
        "noApiKeyCreation",
        "noArbitraryProviderCommand",
        "noWorkerSpawn",
        "noFileMutation",
        "fastModelForbidden",
        "vipChannelForbidden",
        "textToVideoMainPathForbidden",
        "bgmInVideoPromptForbidden"
      ],
      "properties": {
        "handoffId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceActionConfirmationRequestId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourcePermissionRequestId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceReceiptId": { "type": "string" },
        "sourceGateId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "providerId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "slot": { "$ref": "common.schema.json#/$defs/providerSlot" },
        "requiredMode": { "$ref": "common.schema.json#/$defs/requiredMode" },
        "shotId": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "reviewOrder": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewStep" }
        },
        "receiptConfirmed": { "type": "boolean" },
        "userConfirmedAtActionTime": { "type": "boolean" },
        "confirmedReceiptCount": { "type": "integer", "minimum": 0 },
        "canEnterFinalUserHandoffReview": { "type": "boolean" },
        "finalActionGateRequired": { "const": true },
        "finalUserReviewRequired": { "const": true },
        "handoffPlanOnly": { "const": true },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "automaticSubmitAllowed": { "const": false },
        "canSpawnWorker": { "const": false },
        "fileMutationAllowed": { "const": false },
        "dryRunOnly": { "const": true },
        "readOnly": { "const": true },
        "noProviderSubmit": { "const": true },
        "noCredentialRead": { "const": true },
        "noCredentialWrite": { "const": true },
        "noApiKeyCreation": { "const": true },
        "noArbitraryProviderCommand": { "const": true },
        "noWorkerSpawn": { "const": true },
        "noFileMutation": { "const": true },
        "fastModelForbidden": { "const": true },
        "vipChannelForbidden": { "const": true },
        "textToVideoMainPathForbidden": { "const": true },
        "bgmInVideoPromptForbidden": { "const": true }
      }
    },
    "hardLocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "automaticSubmitAllowed",
        "canSpawnWorker",
        "fileMutationAllowed",
        "dryRunOnly",
        "readOnly",
        "handoffPlanOnly",
        "finalActionGateRequired",
        "noProviderSubmit",
        "noCredentialRead",
        "noCredentialWrite",
        "noApiKeyCreation",
        "noArbitraryProviderCommand",
        "noWorkerSpawn",
        "noFileMutation",
        "fastModelForbidden",
        "vipChannelForbidden",
        "textToVideoMainPathForbidden",
        "bgmInVideoPromptForbidden"
      ],
      "properties": {
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "automaticSubmitAllowed": { "const": false },
        "canSpawnWorker": { "const": false },
        "fileMutationAllowed": { "const": false },
        "dryRunOnly": { "const": true },
        "readOnly": { "const": true },
        "handoffPlanOnly": { "const": true },
        "finalActionGateRequired": { "const": true },
        "noProviderSubmit": { "const": true },
        "noCredentialRead": { "const": true },
        "noCredentialWrite": { "const": true },
        "noApiKeyCreation": { "const": true },
        "noArbitraryProviderCommand": { "const": true },
        "noWorkerSpawn": { "const": true },
        "noFileMutation": { "const": true },
        "fastModelForbidden": { "const": true },
        "vipChannelForbidden": { "const": true },
        "textToVideoMainPathForbidden": { "const": true },
        "bgmInVideoPromptForbidden": { "const": true }
      }
    },
    "phase33Evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phaseId",
        "typedEvidencePresent",
        "phase32ReceiptStateConsumed",
        "phase32RequestsObserved",
        "phase32ReceiptsObserved",
        "confirmedReceiptCountObserved",
        "userConfirmedAtActionTimeObserved",
        "allPhase32ProviderRoutesClosed",
        "handoffPlanOnly",
        "finalActionGateRequired",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "automaticSubmitAllowed",
        "canSpawnWorker",
        "fileMutationAllowed",
        "noProviderSubmit",
        "noCredentialRead",
        "noCredentialWrite",
        "noApiKeyCreation",
        "noArbitraryProviderCommand",
        "noWorkerSpawn",
        "noFileMutation"
      ],
      "properties": {
        "phaseId": { "const": "phase_33_provider_execution_handoff" },
        "typedEvidencePresent": { "const": true },
        "phase32ReceiptStateConsumed": { "type": "boolean" },
        "phase32RequestsObserved": { "type": "integer", "minimum": 0 },
        "phase32ReceiptsObserved": { "type": "integer", "minimum": 0 },
        "confirmedReceiptCountObserved": { "type": "integer", "minimum": 0 },
        "userConfirmedAtActionTimeObserved": { "type": "boolean" },
        "allPhase32ProviderRoutesClosed": { "type": "boolean" },
        "handoffPlanOnly": { "const": true },
        "finalActionGateRequired": { "const": true },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "automaticSubmitAllowed": { "const": false },
        "canSpawnWorker": { "const": false },
        "fileMutationAllowed": { "const": false },
        "noProviderSubmit": { "const": true },
        "noCredentialRead": { "const": true },
        "noCredentialWrite": { "const": true },
        "noApiKeyCreation": { "const": true },
        "noArbitraryProviderCommand": { "const": true },
        "noWorkerSpawn": { "const": true },
        "noFileMutation": { "const": true }
      }
    }
  }
}

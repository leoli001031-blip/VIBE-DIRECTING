{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/sidecar_permission.schema.json",
  "title": "SidecarPermissionPolicy",
  "description": "Minimal sidecar permission policy for a read-only settings shell and controlled future sidecar commands.",
  "type": "object",
  "additionalProperties": false,
  "required": ["arbitraryShellExecution", "providerLiveSubmit", "filesystemScope", "allowedCommands", "notes"],
  "properties": {
    "arbitraryShellExecution": {
      "type": "string",
      "enum": ["blocked"]
    },
    "providerLiveSubmit": {
      "type": "string",
      "enum": ["blocked"]
    },
    "filesystemScope": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["project_root", "user_selected_import", "app_config", "temp_dir"]
      }
    },
    "allowedCommands": {
      "type": "array",
      "items": { "$ref": "#/$defs/sidecarAllowedCommand" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "sidecarAllowedCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "executable", "allowedArgs", "requiredFor", "notes"],
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "executable": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "allowedArgs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiredFor": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}

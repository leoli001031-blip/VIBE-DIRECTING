{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/knowledge_pack.schema.json",
  "title": "KnowledgePack",
  "description": "A versioned, hash-locked knowledge pack that may be routed into bounded task context.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "hash",
    "path",
    "type",
    "category",
    "title",
    "summary",
    "tags",
    "applicableTaskPurposes",
    "applicableProviderSlots",
    "dependencies",
    "conflicts",
    "maxInjectionTokens",
    "trustLevel",
    "enabled",
    "defaultEnabled",
    "createdAt",
    "updatedAt",
    "snippets"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "version": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "hash": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "path": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "type": { "$ref": "common.schema.json#/$defs/knowledgePackType" },
    "category": { "$ref": "common.schema.json#/$defs/knowledgePackCategory" },
    "title": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "summary": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "tags": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "uniqueItems": true
    },
    "applicableTaskPurposes": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/knowledgeTaskPurpose" },
      "uniqueItems": true
    },
    "applicableProviderSlots": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/providerSlot" },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packId"],
        "properties": {
          "packId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "version": { "type": "string" },
          "optional": { "type": "boolean" },
          "reason": { "type": "string" }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["packId", "reason"],
        "properties": {
          "packId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "reason": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        }
      }
    },
    "maxInjectionTokens": { "type": "integer", "minimum": 1 },
    "trustLevel": { "$ref": "common.schema.json#/$defs/knowledgePackTrustLevel" },
    "verificationStatus": {
      "type": "string",
      "enum": ["not_required", "pending", "verified", "failed"]
    },
    "verificationReportId": { "type": "string" },
    "conflictAcknowledged": { "type": "boolean" },
    "enabled": { "type": "boolean" },
    "defaultEnabled": { "type": "boolean" },
    "createdAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "updatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "sourcePath": { "type": "string" },
    "snippets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "content", "keywords"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "title": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "summary": { "type": "string" },
          "content": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "keywords": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
            "uniqueItems": true
          },
          "hash": { "type": "string" },
          "tokenEstimate": { "type": "integer", "minimum": 1 },
          "sourceHeading": { "type": "string" }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/project_transaction.schema.json",
  "title": "ProjectTransactionRuntimeState",
  "description": "Pending-only Project.vibe natural-language transaction runtime with source facts, stale artifact summary, validated task enqueue plan, queue ingest facts, dry_run_staged project facts commit receipts, and dry_run_project_store_apply_plan review layers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "userStatus",
    "pendingTransaction",
    "projectFactsWriteGate",
    "projectVibeWritePlan",
    "queueIngestSummary",
    "runtimeEvents",
    "hardLocks",
    "nextUiProjection"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "generatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "userStatus": { "$ref": "#/$defs/userStatus" },
    "pendingTransaction": { "$ref": "#/$defs/pendingTransaction" },
    "projectFactsWriteGate": { "$ref": "#/$defs/projectFactsWriteGate" },
    "projectVibeWritePlan": { "$ref": "#/$defs/projectVibeWritePlan" },
    "queueIngestSummary": { "$ref": "#/$defs/queueSummary" },
    "runtimeEvents": {
      "type": "array",
      "items": { "$ref": "#/$defs/runtimeEvent" }
    },
    "hardLocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pendingOnly",
        "noFileMutation",
        "projectVibeWriteAllowed",
        "providerSubmissionForbidden",
        "workerSpawnForbidden"
      ],
      "properties": {
        "pendingOnly": { "type": "boolean", "const": true },
        "noFileMutation": { "type": "boolean", "const": true },
        "projectVibeWriteAllowed": { "type": "boolean", "const": false },
        "providerSubmissionForbidden": { "type": "boolean", "const": true },
        "workerSpawnForbidden": { "type": "boolean", "const": true }
      }
    },
    "nextUiProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "shortLabel", "queuedCount", "parkedCount", "blockedCount", "staleArtifactCount"],
      "properties": {
        "status": { "$ref": "#/$defs/userStatus" },
        "shortLabel": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "queuedCount": { "type": "integer", "minimum": 0 },
        "parkedCount": { "type": "integer", "minimum": 0 },
        "blockedCount": { "type": "integer", "minimum": 0 },
        "staleArtifactCount": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "userStatus": {
      "type": "string",
      "enum": [
        "waiting_confirmation",
        "pending_project_facts",
        "queued",
        "parked",
        "blocked_missing_knowledge_trace",
        "blocked"
      ]
    },
    "pendingTransaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "schemaVersion",
        "status",
        "userStatus",
        "createdAt",
        "sourceFacts",
        "components",
        "storyChange",
        "assetUpdate",
        "shotReflow",
        "artifactInvalidation",
        "taskEnqueue",
        "projectFactsWriteGate",
        "noFileMutation",
        "providerSubmissionForbidden",
        "projectVibeWriteAllowed"
      ],
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
        "status": { "type": "string", "const": "pending" },
        "userStatus": { "$ref": "#/$defs/userStatus" },
        "createdAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
        "sourceFacts": { "$ref": "#/$defs/sourceFacts" },
        "components": {
          "type": "array",
          "items": { "$ref": "#/$defs/component" },
          "minItems": 5
        },
        "storyChange": { "$ref": "story_change_transaction.schema.json" },
        "assetUpdate": { "$ref": "#/$defs/component" },
        "shotReflow": { "$ref": "#/$defs/component" },
        "artifactInvalidation": { "$ref": "#/$defs/artifactInvalidation" },
        "taskEnqueue": { "$ref": "#/$defs/taskEnqueue" },
        "projectFactsWriteGate": { "$ref": "#/$defs/projectFactsWriteGate" },
        "noFileMutation": { "type": "boolean", "const": true },
        "providerSubmissionForbidden": { "type": "boolean", "const": true },
        "projectVibeWriteAllowed": { "type": "boolean", "const": false }
      }
    },
    "sourceFacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectId",
        "projectVersion",
        "projectTitle",
        "projectRoot",
        "projectHash",
        "sourceIndexHash",
        "generatedAt",
        "currentProjectIdentity",
        "selectedScope",
        "selection",
        "userIntent",
        "staleArtifactImpact",
        "expectedTaskEnqueuePlan",
        "taskEnvelopeIds",
        "sourceRefs",
        "packetPlannerReceipt",
        "knowledgeInjectionTrace"
      ],
      "properties": {
        "projectId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "projectVersion": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "projectTitle": { "type": "string" },
        "projectRoot": { "type": "string" },
        "projectHash": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceIndexHash": { "type": "string" },
        "generatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
        "currentProjectIdentity": { "$ref": "#/$defs/currentProjectIdentity" },
        "selectedScope": { "$ref": "#/$defs/selectedScope" },
        "selection": { "type": "object" },
        "userIntent": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "staleArtifactImpact": { "$ref": "#/$defs/staleArtifactImpact" },
        "expectedTaskEnqueuePlan": { "$ref": "#/$defs/expectedTaskEnqueuePlan" },
        "taskEnvelopeIds": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        },
        "sourceRefs": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        },
        "packetPlannerReceipt": { "$ref": "#/$defs/packetPlannerReceipt" },
        "knowledgeInjectionTrace": { "$ref": "#/$defs/knowledgeTrace" }
      }
    },
    "currentProjectIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projectId", "projectVersion", "projectTitle", "projectRoot", "sourceIndexHash", "sourceIndexRefs"],
      "properties": {
        "projectId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "projectVersion": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "projectTitle": { "type": "string" },
        "projectRoot": { "type": "string" },
        "sourceIndexHash": { "type": "string" },
        "sourceIndexRefs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "selectedScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selectedShotIds", "selectedAssetIds", "targetIds"],
      "properties": {
        "scopeKind": { "type": "string" },
        "selectedShotIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "selectedAssetIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sectionId": { "type": "string" },
        "targetIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "staleArtifactImpact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changeKinds",
        "staleArtifactCount",
        "affectedShotIds",
        "affectedTaskRunIds",
        "affectedEnvelopeIds",
        "affectedExpectedOutputs",
        "requiresRegenerationCount"
      ],
      "properties": {
        "changeKinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["character", "scene", "style", "shot_order", "shot_content", "asset", "voice", "export"]
          }
        },
        "staleArtifactCount": { "type": "integer", "minimum": 0 },
        "affectedShotIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affectedTaskRunIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affectedEnvelopeIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affectedExpectedOutputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiresRegenerationCount": { "type": "integer", "minimum": 0 }
      }
    },
    "expectedTaskEnqueuePlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "validatedEnvelopeRequired",
        "knowledgeTraceRequired",
        "expectedOutputsRequired",
        "qaChecklistRequired",
        "total",
        "queued",
        "parked",
        "blocked",
        "missingKnowledgeTrace",
        "items"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["queued", "parked", "blocked", "empty"] },
        "validatedEnvelopeRequired": { "type": "boolean", "const": true },
        "knowledgeTraceRequired": { "type": "boolean", "const": true },
        "expectedOutputsRequired": { "type": "boolean", "const": true },
        "qaChecklistRequired": { "type": "boolean", "const": true },
        "total": { "type": "integer", "minimum": 0 },
        "queued": { "type": "integer", "minimum": 0 },
        "parked": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "missingKnowledgeTrace": { "type": "integer", "minimum": 0 },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["taskRunId", "packetId", "taskKind", "expectedOutputs", "queueStatus", "validationErrors"],
            "properties": {
              "taskRunId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "packetId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "taskKind": { "$ref": "#/$defs/taskKind" },
              "taskEnvelopeId": { "type": "string" },
              "expectedOutputs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "queueStatus": { "type": "string", "enum": ["queued", "parked", "blocked"] },
              "validationErrors": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "packetPlannerReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receiptId",
        "status",
        "allProductionTaskKindsCovered",
        "validatedEnvelopeRequired",
        "formalTaskRejectsMissingPacket",
        "expectedOutputsIncluded",
        "sourceFactTraceRecorded",
        "knowledgePacksRecorded",
        "phase37VisualConsistencyTraceRequired",
        "noFreeTextWorker",
        "productionTaskKinds",
        "readyKinds",
        "blockedKinds",
        "blockedReasons"
      ],
      "properties": {
        "receiptId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "status": { "type": "string", "enum": ["pass", "blocked"] },
        "allProductionTaskKindsCovered": { "type": "boolean" },
        "validatedEnvelopeRequired": { "type": "boolean", "const": true },
        "formalTaskRejectsMissingPacket": { "type": "boolean", "const": true },
        "expectedOutputsIncluded": { "type": "boolean" },
        "sourceFactTraceRecorded": { "type": "boolean" },
        "knowledgePacksRecorded": { "type": "boolean" },
        "phase37VisualConsistencyTraceRequired": { "type": "boolean", "const": true },
        "noFreeTextWorker": { "type": "boolean", "const": true },
        "productionTaskKinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/taskKind" },
          "minItems": 12
        },
        "readyKinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/taskKind" }
        },
        "blockedKinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/taskKind" }
        },
        "blockedReasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "knowledgeTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "totalTaskEnvelopes", "taskEnvelopesWithTrace", "missingTaskEnvelopeIds", "items"],
      "properties": {
        "status": { "type": "string", "enum": ["present", "missing"] },
        "totalTaskEnvelopes": { "type": "integer", "minimum": 0 },
        "taskEnvelopesWithTrace": { "type": "integer", "minimum": 0 },
        "missingTaskEnvelopeIds": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/knowledgeTraceItem" }
        }
      }
    },
    "knowledgeTraceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packetId",
        "taskKind",
        "packCount",
        "snippetIdCount",
        "snippetCount",
        "status",
        "warnings"
      ],
      "properties": {
        "packetId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "taskKind": { "$ref": "#/$defs/taskKind" },
        "envelopeId": { "type": "string" },
        "taskEnvelopeId": { "type": "string" },
        "knowledgeRouteResultId": { "type": "string" },
        "contextBudgetId": { "type": "string" },
        "packCount": { "type": "integer", "minimum": 0 },
        "snippetIdCount": { "type": "integer", "minimum": 0 },
        "snippetCount": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["present", "missing"] },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "sourceId", "status", "targetIds", "summary", "noFileMutation"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["story_change", "asset_update", "shot_reflow", "artifact_invalidation", "task_enqueue"]
        },
        "sourceId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "status": { "type": "string", "const": "pending" },
        "targetIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "noFileMutation": { "type": "boolean", "const": true }
      }
    },
    "artifactInvalidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changeKinds",
        "affectedShotIds",
        "affectedTaskRunIds",
        "affectedEnvelopeIds",
        "affectedExpectedOutputs",
        "staleArtifacts",
        "deleteForbidden",
        "notes"
      ],
      "properties": {
        "changeKinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["character", "scene", "style", "shot_order", "shot_content", "asset", "voice", "export"]
          }
        },
        "affectedShotIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affectedTaskRunIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affectedEnvelopeIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affectedExpectedOutputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "staleArtifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/staleArtifact" }
        },
        "deleteForbidden": { "type": "boolean", "const": true },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "staleArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactId",
        "artifactType",
        "staleReason",
        "requiresRegeneration",
        "affectedTaskKinds",
        "affectedEnvelopeIds",
        "affectedExpectedOutputs"
      ],
      "properties": {
        "artifactId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "artifactType": { "type": "string" },
        "targetId": { "type": "string" },
        "staleReason": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "requiresRegeneration": { "type": "boolean" },
        "affectedTaskKinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/taskKind" }
        },
        "affectedEnvelopeIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affectedExpectedOutputs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "taskEnqueue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "validatedEnvelopeRequired",
        "noFreeTextTask",
        "providerSubmissionForbidden",
        "items",
        "summary"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["queued", "parked", "blocked", "empty"] },
        "validatedEnvelopeRequired": { "type": "boolean", "const": true },
        "noFreeTextTask": { "type": "boolean", "const": true },
        "providerSubmissionForbidden": { "type": "boolean", "const": true },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/taskEnqueueItem" }
        },
        "summary": { "$ref": "#/$defs/queueSummary" }
      }
    },
    "taskEnqueueItem": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "taskRunId",
        "packetId",
        "taskKind",
        "expectedOutputs",
        "providerPolicyStatus",
        "userEnabled",
        "preflightBlocked",
        "validationErrors",
        "knowledgeTraceStatus",
        "queueStatus",
        "queueDecision",
        "ledgerEvents"
      ],
      "properties": {
        "taskRunId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "packetId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "taskKind": { "$ref": "#/$defs/taskKind" },
        "envelopeId": { "type": "string" },
        "taskEnvelopeId": { "type": "string" },
        "expectedOutputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "providerExecutionState": { "$ref": "common.schema.json#/$defs/providerExecutionState" },
        "providerPolicyStatus": { "type": "string", "enum": ["enabled", "parked", "planned", "unavailable"] },
        "userEnabled": { "type": "boolean" },
        "preflightBlocked": { "type": "boolean" },
        "validationErrors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "knowledgeTraceStatus": { "type": "string", "enum": ["present", "missing"] },
        "queueStatus": { "type": "string", "enum": ["queued", "parked", "blocked"] },
        "queueDecision": { "type": "object" },
        "ledgerEvents": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "projectVibeWritePlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "transactionId",
        "noFileMutation",
        "projectVibeWriteAllowed",
        "requiresUserCommit",
        "projectFactsWriteGate",
        "entries",
        "futureApplyInterface",
        "notes"
      ],
      "properties": {
        "mode": { "type": "string", "const": "pending_only" },
        "transactionId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "noFileMutation": { "type": "boolean", "const": true },
        "projectVibeWriteAllowed": { "type": "boolean", "const": false },
        "requiresUserCommit": { "type": "boolean", "const": true },
        "projectFactsWriteGate": { "$ref": "#/$defs/projectFactsWriteGate" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "operation",
              "path",
              "origin",
              "canExecute",
              "noFileMutation",
              "projectVibeWriteAllowed",
              "notes"
            ],
            "properties": {
              "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "operation": { "type": "string", "const": "append_pending_transaction" },
              "path": { "type": "string", "const": "project.vibe" },
              "origin": { "type": "string", "const": "project_root_relative" },
              "canExecute": { "type": "boolean", "const": false },
              "noFileMutation": { "type": "boolean", "const": true },
              "projectVibeWriteAllowed": { "type": "boolean", "const": false },
              "notes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "futureApplyInterface": {
          "type": "object",
          "additionalProperties": false,
          "required": ["confirmPendingTransaction", "applyToProjectFacts", "enqueueValidatedTasks", "requiresKnowledgeTrace"],
          "properties": {
            "confirmPendingTransaction": { "type": "boolean", "const": true },
            "applyToProjectFacts": { "type": "boolean", "const": false },
            "enqueueValidatedTasks": { "type": "boolean", "const": false },
            "requiresKnowledgeTrace": { "type": "boolean", "const": true }
          }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "projectFactsWriteGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transactionId",
        "projectVibeWriteAllowed",
        "requiresUserCommit",
        "noFileMutation",
        "canWriteNow",
        "futureFactRoles",
        "blockedBy",
        "notes"
      ],
      "properties": {
        "transactionId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "projectVibeWriteAllowed": { "type": "boolean", "const": false },
        "requiresUserCommit": { "type": "boolean", "const": true },
        "noFileMutation": { "type": "boolean", "const": true },
        "canWriteNow": { "type": "boolean", "const": false },
        "futureFactRoles": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "operation", "sourceComponentKinds", "reason"],
            "properties": {
              "role": {
                "type": "string",
                "enum": ["story_flow", "visual_memory", "shot_layout", "source_index", "task_runs_pointer", "knowledge_route_history"]
              },
              "operation": { "type": "string", "enum": ["append_pending", "update_on_user_commit", "link_on_user_commit"] },
              "sourceComponentKinds": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["story_change", "asset_update", "shot_reflow", "artifact_invalidation", "task_enqueue"]
                }
              },
              "reason": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
            }
          }
        },
        "blockedBy": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "projectFactsStagedCommitReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "receiptId",
        "transactionId",
        "sourceConfirmationReceiptId",
        "generatedAt",
        "status",
        "mode",
        "requiresConfirmedReceipt",
        "stagedOnly",
        "pendingFactPatches",
        "stagingSummary",
        "blockedReasons",
        "nextAction",
        "hardLocks",
        "projectVibeWritten",
        "providerCalled",
        "workerSpawned"
      ],
      "properties": {
        "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
        "receiptId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "transactionId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },

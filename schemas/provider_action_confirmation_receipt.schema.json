{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/provider_action_confirmation_receipt.schema.json",
  "title": "ProviderActionConfirmationReceiptState",
  "description": "Phase 32 action-time confirmation receipt review shell. It records typed receipt placeholders from Phase 31 permission requests and never submits providers, spawns workers, reads credentials, or mutates files.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "phase", "requests", "receipts", "summary", "hardLocks", "phase32Evidence", "forbiddenActions", "notes"],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "generatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "phase": { "const": "phase_32_action_time_confirmation_receipt" },
    "requests": {
      "type": "array",
      "items": { "$ref": "#/$defs/request" }
    },
    "receipts": {
      "type": "array",
      "items": { "$ref": "#/$defs/receipt" }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalRequests",
        "readyForReceipt",
        "blocked",
        "parked",
        "totalReceipts",
        "receiptPlaceholderCount",
        "confirmedReceiptCount",
        "canRecordReceipt",
        "userConfirmedAtActionTime",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "automaticSubmitAllowed"
      ],
      "properties": {
        "totalRequests": { "type": "integer", "minimum": 0 },
        "readyForReceipt": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "parked": { "type": "integer", "minimum": 0 },
        "totalReceipts": { "type": "integer", "minimum": 0 },
        "receiptPlaceholderCount": { "type": "integer", "minimum": 0 },
        "confirmedReceiptCount": { "type": "integer", "const": 0 },
        "canRecordReceipt": { "type": "integer", "minimum": 0 },
        "userConfirmedAtActionTime": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "automaticSubmitAllowed": { "const": false }
      }
    },
    "hardLocks": { "$ref": "#/$defs/hardLocks" },
    "phase32Evidence": { "$ref": "#/$defs/phase32Evidence" },
    "forbiddenActions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "provider_submit",
          "automatic_submit",
          "credential_read",
          "credential_write",
          "api_key_create",
          "arbitrary_provider_command",
          "worker_spawn",
          "file_mutation",
          "fast_model",
          "vip_channel",
          "text_to_video_main_path",
          "bgm_in_video_prompt"
        ]
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["ready_for_receipt", "blocked", "parked"]
    },
    "reviewStep": {
      "type": "string",
      "enum": [
        "review_phase31_permission_request",
        "collect_action_time_confirmation",
        "record_confirmation_receipt",
        "hold_for_final_execution_gate"
      ]
    },
    "receiptKind": {
      "type": "string",
      "enum": ["action_time_user_confirmation_receipt"]
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestId",
        "sourcePermissionRequestId",
        "sourceGateId",
        "sourceId",
        "providerId",
        "slot",
        "requiredMode",
        "receiptId",
        "status",
        "blockers",
        "warnings",
        "reviewOrder",
        "canRecordReceipt",
        "confirmationReceiptRequired",
        "confirmationReceiptPlaceholderPresent",
        "actionTimeConfirmationRequired",
        "userConfirmedAtActionTime",
        "confirmedReceiptCount",
        "finalExecutionGateRequired",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "automaticSubmitAllowed",
        "credentialStorage",
        "dryRunOnly",
        "readOnly",
        "noCredentialRead",
        "noCredentialWrite",
        "noApiKeyCreation",
        "noArbitraryProviderCommand",
        "noWorkerSpawn",
        "noFileMutation"
      ],
      "properties": {
        "requestId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourcePermissionRequestId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceGateId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "providerId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "slot": { "$ref": "common.schema.json#/$defs/providerSlot" },
        "requiredMode": { "$ref": "common.schema.json#/$defs/requiredMode" },
        "shotId": { "type": "string" },
        "receiptId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "status": { "$ref": "#/$defs/status" },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "reviewOrder": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewStep" }
        },
        "canRecordReceipt": { "type": "boolean" },
        "confirmationReceiptRequired": { "const": true },
        "confirmationReceiptPlaceholderPresent": { "const": true },
        "actionTimeConfirmationRequired": { "const": true },
        "userConfirmedAtActionTime": { "const": false },
        "confirmedReceiptCount": { "type": "integer", "const": 0 },
        "finalExecutionGateRequired": { "const": true },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "automaticSubmitAllowed": { "const": false },
        "credentialStorage": { "const": false },
        "dryRunOnly": { "const": true },
        "readOnly": { "const": true },
        "noCredentialRead": { "const": true },
        "noCredentialWrite": { "const": true },
        "noApiKeyCreation": { "const": true },
        "noArbitraryProviderCommand": { "const": true },
        "noWorkerSpawn": { "const": true },
        "noFileMutation": { "const": true }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receiptId",
        "sourcePermissionRequestId",
        "sourceGateId",
        "sourceId",
        "providerId",
        "slot",
        "requiredMode",
        "status",
        "receiptKind",
        "placeholderPresent",
        "typedEvidencePresent",
        "confirmationRequired",
        "actionTimeConfirmationRequired",
        "userConfirmedAtActionTime",
        "confirmed",
        "confirmedReceiptCount",
        "finalExecutionGateRequired",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "automaticSubmitAllowed",
        "credentialStorage",
        "dryRunOnly",
        "readOnly",
        "noCredentialRead",
        "noCredentialWrite",
        "noApiKeyCreation",
        "noArbitraryProviderCommand",
        "noWorkerSpawn",
        "noFileMutation",
        "blockers",
        "warnings"
      ],
      "properties": {
        "receiptId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourcePermissionRequestId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceGateId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "providerId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "slot": { "$ref": "common.schema.json#/$defs/providerSlot" },
        "requiredMode": { "$ref": "common.schema.json#/$defs/requiredMode" },
        "shotId": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "receiptKind": { "$ref": "#/$defs/receiptKind" },
        "placeholderPresent": { "const": true },
        "typedEvidencePresent": { "const": true },
        "confirmationRequired": { "const": true },
        "actionTimeConfirmationRequired": { "const": true },
        "userConfirmedAtActionTime": { "const": false },
        "confirmed": { "const": false },
        "confirmedReceiptCount": { "type": "integer", "const": 0 },
        "finalExecutionGateRequired": { "const": true },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "automaticSubmitAllowed": { "const": false },
        "credentialStorage": { "const": false },
        "dryRunOnly": { "const": true },
        "readOnly": { "const": true },
        "noCredentialRead": { "const": true },
        "noCredentialWrite": { "const": true },
        "noApiKeyCreation": { "const": true },
        "noArbitraryProviderCommand": { "const": true },
        "noWorkerSpawn": { "const": true },
        "noFileMutation": { "const": true },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "hardLocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dryRunOnly",
        "readOnly",
        "reviewShellOnly",
        "receiptPlanOnly",
        "actionTimeConfirmationRequired",
        "finalExecutionGateRequired",
        "providerSubmissionForbidden",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "automaticSubmitAllowed",
        "credentialStorage",
        "noCredentialRead",
        "noCredentialWrite",
        "noApiKeyCreation",
        "noArbitraryProviderCommand",
        "noWorkerSpawn",
        "noFileMutation",
        "fastModelForbidden",
        "vipChannelForbidden",
        "textToVideoMainPathForbidden",
        "bgmInVideoPromptForbidden"
      ],
      "properties": {
        "dryRunOnly": { "const": true },
        "readOnly": { "const": true },
        "reviewShellOnly": { "const": true },
        "receiptPlanOnly": { "const": true },
        "actionTimeConfirmationRequired": { "const": true },
        "finalExecutionGateRequired": { "const": true },
        "providerSubmissionForbidden": { "const": true },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "automaticSubmitAllowed": { "const": false },
        "credentialStorage": { "const": false },
        "noCredentialRead": { "const": true },
        "noCredentialWrite": { "const": true },
        "noApiKeyCreation": { "const": true },
        "noArbitraryProviderCommand": { "const": true },
        "noWorkerSpawn": { "const": true },
        "noFileMutation": { "const": true },
        "fastModelForbidden": { "const": true },
        "vipChannelForbidden": { "const": true },
        "textToVideoMainPathForbidden": { "const": true },
        "bgmInVideoPromptForbidden": { "const": true }
      }
    },
    "phase32Evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phaseId",
        "typedEvidencePresent",
        "phase31GateConsumed",
        "phase31RequestsMirrored",
        "receiptPlaceholdersPresent",
        "defaultUserConfirmedAtActionTime",
        "confirmedReceiptCount",
        "actionTimeConfirmationRequired",
        "finalExecutionGateRequired",
        "automaticSubmitForbidden",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "noWorkerSpawn",
        "noFileMutation"
      ],
      "properties": {
        "phaseId": { "const": "phase_32_action_time_confirmation_receipt" },
        "typedEvidencePresent": { "const": true },
        "phase31GateConsumed": { "type": "boolean" },
        "phase31RequestsMirrored": { "type": "integer", "minimum": 0 },
        "receiptPlaceholdersPresent": { "const": true },
        "defaultUserConfirmedAtActionTime": { "const": false },
        "confirmedReceiptCount": { "type": "integer", "const": 0 },
        "actionTimeConfirmationRequired": { "const": true },
        "finalExecutionGateRequired": { "const": true },
        "automaticSubmitForbidden": { "const": true },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "noWorkerSpawn": { "const": true },
        "noFileMutation": { "const": true }
      }
    }
  }
}

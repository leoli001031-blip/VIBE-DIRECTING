{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/keyframe_pair_derivation.schema.json",
  "title": "KeyframePairDerivation",
  "description": "Proof that an end frame is derived from the start frame or has an explicit exception.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "shotId",
    "startFrameId",
    "endFrameId",
    "endDerivationSource",
    "validForI2vPair",
    "allowedDelta",
    "mustPreserve",
    "mustNotAdd"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "shotId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "startFrameId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "endFrameId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "startFrameHash": { "type": "string" },
    "endFrameHash": { "type": "string" },
    "endDerivationSource": {
      "type": "string",
      "enum": ["start_frame", "independent_exception", "unknown"]
    },
    "sourceStartFrameRequired": { "type": "boolean", "const": true },
    "independentEndFrameAllowed": { "type": "boolean", "const": false },
    "validForI2vPair": { "type": "boolean" },
    "pairGate": { "$ref": "#/$defs/pairGate" },
    "semanticChecks": { "$ref": "#/$defs/semanticChecks" },
    "exceptionReason": { "type": "string" },
    "allowedDelta": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
    },
    "mustPreserve": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
    },
    "mustNotAdd": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
    }
  },
  "$defs": {
    "pairGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "endFrameDerivesFromStart", "sameShotIndependentEndFrameForbidden"],
      "properties": {
        "status": { "$ref": "common.schema.json#/$defs/gateStatus" },
        "endFrameDerivesFromStart": { "type": "boolean", "const": true },
        "sameShotIndependentEndFrameForbidden": { "type": "boolean", "const": true },
        "sourceRefs": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        }
      }
    },
    "semanticChecks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "scene", "story", "prop", "style", "motion"],
      "properties": {
        "identity": { "$ref": "common.schema.json#/$defs/gateStatus" },
        "scene": { "$ref": "common.schema.json#/$defs/gateStatus" },
        "story": { "$ref": "common.schema.json#/$defs/gateStatus" },
        "prop": { "$ref": "common.schema.json#/$defs/gateStatus" },
        "style": { "$ref": "common.schema.json#/$defs/gateStatus" },
        "motion": { "$ref": "common.schema.json#/$defs/gateStatus" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "endDerivationSource": { "const": "unknown" }
        },
        "required": ["endDerivationSource"]
      },
      "then": {
        "properties": {
          "validForI2vPair": { "const": false }
        }
      }
    },
    {
      "if": {
        "properties": {
          "endDerivationSource": { "const": "independent_exception" }
        },
        "required": ["endDerivationSource"]
      },
      "then": {
        "required": ["exceptionReason"]
      }
    }
  ]
}

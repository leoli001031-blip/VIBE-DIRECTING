{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/prompt_conflict_report.schema.json",
  "title": "PromptConflictReport",
  "description": "Prompt compiler conflicts before a prompt plan can become an envelope input.",
  "type": "object",
  "additionalProperties": false,
  "required": ["reportId", "promptPlanId", "jobId", "status", "conflicts", "checkedAt"],
  "properties": {
    "reportId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "promptPlanId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "jobId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "shotId": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["clear", "warning", "blocked"]
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "detail"],
        "properties": {
          "code": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
          "severity": {
            "type": "string",
            "enum": ["blocker", "warning", "info"]
          },
          "target": { "type": "string" },
          "detail": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
        }
      }
    },
    "checkedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/task_run_ledger.schema.json",
  "title": "TaskRunLedger",
  "description": "Append-only task runtime event ledger. Manifest, report, preview, and creator progress are projections from these events, not separate sources of truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "ledgerId",
    "taskRunId",
    "createdAt",
    "updatedAt",
    "expectedOutputs",
    "events"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "ledgerId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "projectId": { "type": "string" },
    "taskRunId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "envelopeId": { "type": "string" },
    "createdAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "updatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "expectedOutputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/portablePath" },
      "uniqueItems": true
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "prepared",
        "queued",
        "leased",
        "running",
        "waiting_output",
        "output_detected_no_sidecar",
        "provider_observed",
        "qa_pending",
        "needs_review",
        "complete_verified",
        "stalled",
        "interrupted",
        "failed",
        "parked"
      ]
    },
    "eventType": {
      "type": "string",
      "enum": [
        "task_prepared",
        "task_queued",
        "task_leased",
        "task_running",
        "task_waiting_output",
        "output_detected_no_sidecar",
        "provider_observed",
        "qa_pending",
        "qa_passed",
        "needs_review",
        "complete_verified",
        "stalled",
        "interrupted",
        "failed",
        "parked",
        "worker_self_reported_success"
      ]
    },
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "anyOf": [
          { "pattern": "^[A-Za-z]:[\\\\/]" },
          { "pattern": "^/" },
          { "pattern": "^//" },
          { "pattern": "^~[\\\\/]" },
          { "pattern": "(^|/)\\.\\.(/|$)" }
        ]
      }
    },
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner"],
      "properties": {
        "owner": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "leaseId": { "type": "string" },
        "workerId": { "type": "string" },
        "threadId": { "type": "string" },
        "turnId": { "type": "string" },
        "leasedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
        "expiresAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
        "status": {
          "type": "string",
          "enum": ["leased", "running", "stalled", "interrupted", "failed", "released"]
        },
        "retryBudget": { "type": "integer", "minimum": 0 },
        "retryCount": { "type": "integer", "minimum": 0 },
        "stallTimeoutSeconds": { "type": "integer", "minimum": 0 },
        "resumePolicy": {
          "type": "string",
          "enum": ["resume_same_worker", "reassign_allowed", "fail_on_interrupt", "manual_review"]
        }
      }
    },
    "outputEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "hash"],
      "properties": {
        "path": { "$ref": "#/$defs/portablePath" },
        "hash": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "hashAlgorithm": {
          "type": "string",
          "enum": ["sha256", "sha1", "md5", "unknown"]
        },
        "byteLength": { "type": "integer", "minimum": 0 }
      }
    },
    "providerObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outputPath", "outputHash"],
      "properties": {
        "providerId": { "type": "string" },
        "observationId": { "type": "string" },
        "outputPath": { "$ref": "#/$defs/portablePath" },
        "outputHash": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sidecarPath": { "$ref": "#/$defs/portablePath" },
        "sidecarHash": { "type": "string" },
        "appServerThreadId": { "type": "string" },
        "appServerTurnId": { "type": "string" },
        "appServerToolCallId": { "type": "string" }
      }
    },
    "qaReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outputPath", "reviewedOutputHash", "status", "findingIds"],
      "properties": {
        "qaReportId": { "type": "string" },
        "outputPath": { "$ref": "#/$defs/portablePath" },
        "reviewedOutputHash": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sidecarPath": { "$ref": "#/$defs/portablePath" },
        "sidecarHash": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending", "pass", "needs_review", "failed"]
        },
        "findingIds": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "p0FindingCount": { "type": "integer", "minimum": 0 },
        "p1FindingCount": { "type": "integer", "minimum": 0 },
        "p2FindingCount": { "type": "integer", "minimum": 0 }
      }
    },
    "workerClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "failed", "cancelled"]
        },
        "outputPath": { "$ref": "#/$defs/portablePath" },
        "outputHash": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventId", "eventType", "at", "notes"],
      "properties": {
        "eventId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "eventType": { "$ref": "#/$defs/eventType" },
        "at": { "$ref": "common.schema.json#/$defs/isoDateTime" },
        "taskRunId": { "type": "string" },
        "envelopeId": { "type": "string" },
        "workerId": { "type": "string" },
        "lease": { "$ref": "#/$defs/lease" },
        "output": { "$ref": "#/$defs/outputEvidence" },
        "providerObservation": { "$ref": "#/$defs/providerObservation" },
        "qaReview": { "$ref": "#/$defs/qaReview" },
        "workerClaim": { "$ref": "#/$defs/workerClaim" },
        "reason": { "type": "string" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "completionGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completeVerified",
        "outputHashPresent",
        "providerObservationPresent",
        "providerObservationHashMatches",
        "providerSidecarHashPresent",
        "qaReviewPresent",
        "qaReviewedHashMatches",
        "qaSidecarHashPresent",
        "qaPassed",
        "workerSelfReportIgnored",
        "blockers"
      ],
      "properties": {
        "completeVerified": { "type": "boolean" },
        "outputHashPresent": { "type": "boolean" },
        "providerObservationPresent": { "type": "boolean" },
        "providerObservationHashMatches": { "type": "boolean" },
        "providerSidecarHashPresent": { "type": "boolean" },
        "qaReviewPresent": { "type": "boolean" },
        "qaReviewedHashMatches": { "type": "boolean" },
        "qaSidecarHashPresent": { "type": "boolean" },
        "qaPassed": { "type": "boolean" },
        "workerSelfReportIgnored": { "type": "boolean" },
        "blockers": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/image2_adapter_request.schema.json",
  "title": "Image2AdapterRequest",
  "description": "Dry-run-only image adapter payload skeleton. It carries source facts and the registry-selected adapter id, not final provider prompt text.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requestId",
    "taskPlanId",
    "adapterId",
    "operation",
    "payload",
    "submitPolicy",
    "forbiddenFallbacks"
  ],
  "properties": {
    "requestId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "taskPlanId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "adapterId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "operation": {
      "type": "string",
      "enum": ["text2image", "image2image", "reference_asset"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceIntent", "mustPreserve", "mustAvoid", "references", "referenceImageInputs", "outputPath"],
      "properties": {
        "sourceIntent": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mustPreserve": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mustAvoid": {
          "type": "array",
          "items": { "type": "string" }
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["referenceId", "source"],
            "properties": {
              "referenceId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "source": { "type": "string", "const": "prompt_plan" }
            }
          }
        },
        "referenceImageInputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/referenceImageInput" }
        },
        "sourceStartFrameId": { "type": "string" },
        "outputPath": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "submitPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dry_run_only", "manual_submit_required", "live_submit_forbidden"],
      "properties": {
        "dry_run_only": { "type": "boolean", "const": true },
        "manual_submit_required": { "type": "boolean", "const": true },
        "live_submit_forbidden": { "type": "boolean", "const": true }
      }
    },
    "forbiddenFallbacks": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "type": "string", "enum": ["provider_or_mode_fallback"] }
    }
  },
  "$defs": {
    "referenceImageInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inputId", "role", "path", "source", "required", "mustUseAsVisualInput", "status", "notes"],
      "properties": {
        "inputId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "role": {
          "type": "string",
          "enum": [
            "source_start_frame",
            "locked_character_reference",
            "locked_scene_reference",
            "locked_style_reference",
            "locked_prop_reference",
            "mask",
            "other"
          ]
        },
        "path": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "source": {
          "type": "string",
          "enum": ["approved_start_frame", "locked_asset", "candidate_asset", "task_envelope", "manual_user_input"]
        },
        "required": { "type": "boolean", "const": true },
        "mustUseAsVisualInput": { "type": "boolean", "const": true },
        "status": { "type": "string", "enum": ["available", "planned", "missing", "blocked"] },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operation": { "const": "image2image" }
        },
        "required": ["operation"]
      },
      "then": {
        "properties": {
          "payload": {
            "properties": {
              "referenceImageInputs": {
                "contains": {
                  "type": "object",
                  "properties": {
                    "role": { "const": "source_start_frame" },
                    "source": { "const": "approved_start_frame" },
                    "required": { "const": true },
                    "mustUseAsVisualInput": { "const": true },
                    "status": { "const": "available" }
                  },
                  "required": ["role", "path", "source", "required", "mustUseAsVisualInput", "status"]
                }
              }
            }
          },
          "forbiddenFallbacks": {
            "contains": { "const": "image2image_to_text2image" }
          }
        }
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/project_runtime_state.schema.json",
  "title": "ProjectRuntimeState",
  "description": "The first-class runtime state file consumed by the Vibe Core director desk.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "coreStateVersion",
    "generatedAt",
    "project",
    "projectFileCore",
    "sourceIndex",
    "sourceIndexSummary",
    "storyFlow",
    "visualMemory",
    "taskRuns",
    "manifestMatches",
    "imagePipeline",
    "imageKeyframeRuntime",
    "previewEvents",
    "previewExport",
    "exportWorker",
    "voiceSourceLibrary",
    "audioPlanning",
    "voiceAudioSettings",
    "videoPlanning",
    "videoExecutionPreview",
    "adapterContracts",
    "providerLiveGate",
    "providerExecutionPermissionGate",
    "providerActionConfirmationReceipt",
    "providerExecutionHandoff",
    "executionLedger",
    "realExecutionGate",
    "realProviderPilot",
    "realProviderExecutor",
    "realProviderOneShotTest",
    "localOrchestrator",
    "generationHarness",
    "filesystemWatcherHarness",
    "checkpointResumeHarness",
    "qaHarness",
    "toolRuntimeHarness",
    "subagentRunner",
    "agentCliMockRunner",
    "codexCliAdapterSpike",
    "generationHealthChecker",
    "promptConflictChecker",
    "storyChanges",
    "runtime",
    "diagnostics",
    "knowledge",
    "stateSource"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "coreStateVersion": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "generatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "project": {
      "type": "object",
      "additionalProperties": true,
      "required": ["title", "root", "sourceTask", "state", "importedAt", "metrics", "providerPolicy", "workflow", "contactSheets"],
      "properties": {
        "title": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "root": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceTask": { "type": "string" },
        "state": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "importedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
        "metrics": { "type": "object" },
        "providerPolicy": { "type": "object" },
        "workflow": { "type": "array", "items": { "type": "object" } },
        "contactSheets": { "type": "object" }
      }
    },
    "projectFileCore": { "$ref": "project_file_core.schema.json" },
    "projectFactsIntegration": { "$ref": "project_facts_integration.schema.json" },
    "sourceIndex": { "$ref": "project_source_index.schema.json" },
    "sourceIndexSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectId",
        "projectVersion",
        "sourceIndexHash",
        "currentSourceCount",
        "promptHashCount",
        "lockedReferenceCount",
        "candidateReferenceCount",
        "rejectedReferenceCount",
        "failedReferenceCount",
        "confirmedDecisionCount",
        "staleArtifactCount",
        "updatedAt",
        "isProductionReady",
        "blockingReferenceCount"
      ],
      "properties": {
        "projectId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "projectVersion": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceIndexHash": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "currentSourceCount": { "type": "integer", "minimum": 0 },
        "promptHashCount": { "type": "integer", "minimum": 0 },
        "lockedReferenceCount": { "type": "integer", "minimum": 0 },
        "candidateReferenceCount": { "type": "integer", "minimum": 0 },
        "rejectedReferenceCount": { "type": "integer", "minimum": 0 },
        "failedReferenceCount": { "type": "integer", "minimum": 0 },
        "confirmedDecisionCount": { "type": "integer", "minimum": 0 },
        "staleArtifactCount": { "type": "integer", "minimum": 0 },
        "updatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
        "isProductionReady": { "type": "boolean" },
        "blockingReferenceCount": { "type": "integer", "minimum": 0 }
      }
    },
    "storyFlow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections", "shots"],
      "properties": {
        "sections": { "type": "array", "items": { "type": "object" } },
        "shots": { "type": "array", "items": { "type": "object" } }
      }
    },
    "visualMemory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "assets"],
      "properties": {
        "summary": { "type": "object" },
        "assets": { "type": "array", "items": { "type": "object" } }
      }
    },
    "taskRuns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["jobs", "runs", "taskViews", "queueSummary", "preflightSummary"],
      "properties": {
        "jobs": { "type": "array", "items": { "type": "object" } },
        "runs": { "type": "array", "items": { "$ref": "task_run.schema.json" } },
        "taskViews": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["job", "envelope", "taskRun", "queueGate", "manifestMatch", "validator", "routeResult", "contextBudget", "nextStep"],
            "properties": {
              "job": { "type": "object" },
              "shotId": { "type": "string" },
              "envelope": { "$ref": "task_envelope.schema.json" },
              "taskRun": { "$ref": "task_run.schema.json" },
              "queueGate": { "type": "object" },
              "manifestMatch": { "type": "object" },
              "validator": { "type": "object" },
              "routeResult": { "$ref": "knowledge_route_result.schema.json" },
              "contextBudget": { "$ref": "context_budget.schema.json" },
              "nextStep": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
            }
          }
        },
        "queueSummary": { "type": "object" },
        "preflightSummary": { "type": "object" }
      }
    },
    "manifestMatches": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "reports"],
      "properties": {
        "summary": { "type": "object" },
        "reports": { "type": "array", "items": { "type": "object" } }
      }
    },
    "imagePipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "providerRegistry",
        "promptPlans",
        "promptConflictReports",
        "assetReadinessReports",
        "imageTaskPlans",
        "image2AdapterRequests",
        "watcherEvents",
        "generationHealthReports",
        "qaPromotionReports"
      ],
      "properties": {
        "providerRegistry": { "$ref": "provider_registry.schema.json" },
        "promptPlans": {
          "type": "array",
          "items": { "$ref": "shot_prompt_plan.schema.json" }
        },
        "promptConflictReports": {
          "type": "array",
          "items": { "$ref": "prompt_conflict_report.schema.json" }
        },
        "assetReadinessReports": {
          "type": "array",
          "items": { "$ref": "asset_readiness_report.schema.json" }
        },
        "imageTaskPlans": {
          "type": "array",
          "items": { "$ref": "image_task_plan.schema.json" }
        },
        "image2AdapterRequests": {
          "type": "array",
          "items": { "$ref": "image2_adapter_request.schema.json" }
        },
        "watcherEvents": {
          "type": "array",
          "items": { "$ref": "watcher_event.schema.json" }
        },
        "generationHealthReports": {
          "type": "array",
          "items": { "$ref": "generation_health_report.schema.json" }
        },
        "qaPromotionReports": {
          "type": "array",
          "items": { "$ref": "qa_promotion_report.schema.json" }
        }
      }
    },
    "imageKeyframeRuntime": { "$ref": "image_keyframe_runtime.schema.json" },
    "previewEvents": { "type": "array", "items": { "$ref": "preview_event.schema.json" } },
    "previewExport": { "$ref": "preview_plan.schema.json#/$defs/projectPreviewExportState" },
    "exportWorker": { "$ref": "export_worker.schema.json" },
    "voiceSourceLibrary": { "$ref": "voice_source_library.schema.json" },
    "audioPlanning": { "$ref": "audio_plan.schema.json#/$defs/audioPlanningState" },
    "voiceAudioSettings": { "$ref": "voice_audio_settings.schema.json" },
    "videoPlanning": { "$ref": "video_task_plan.schema.json#/$defs/videoPlanningState" },
    "videoExecutionPreview": { "$ref": "video_execution_preview.schema.json#/$defs/videoExecutionPreviewState" },
    "adapterContracts": { "$ref": "adapter_contract.schema.json" },
    "providerLiveGate": { "$ref": "provider_live_gate.schema.json" },
    "providerExecutionPermissionGate": { "$ref": "provider_execution_permission_gate.schema.json" },
    "providerActionConfirmationReceipt": { "$ref": "provider_action_confirmation_receipt.schema.json" },
    "providerExecutionHandoff": { "$ref": "provider_execution_handoff.schema.json" },
    "executionLedger": { "$ref": "execution_ledger.schema.json" },
    "realExecutionGate": { "$ref": "real_execution_gate.schema.json" },
    "realProviderPilot": { "$ref": "real_provider_pilot.schema.json" },
    "realProviderExecutor": { "$ref": "real_provider_executor.schema.json" },
    "realProviderOneShotTest": { "$ref": "real_provider_one_shot_test.schema.json" },
    "localOrchestrator": { "$ref": "local_orchestrator.schema.json" },
    "generationHarness": { "$ref": "generation_harness.schema.json" },
    "filesystemWatcherHarness": { "$ref": "filesystem_watcher_harness.schema.json" },
    "checkpointResumeHarness": { "$ref": "checkpoint_resume_harness.schema.json" },
    "qaHarness": { "$ref": "qa_harness.schema.json" },
    "toolRuntimeHarness": { "$ref": "tool_runtime_harness.schema.json" },
    "subagentRunner": { "$ref": "subagent_runner.schema.json" },
    "agentCliMockRunner": { "$ref": "agent_cli_mock_runner.schema.json" },
    "codexCliAdapterSpike": { "$ref": "codex_cli_adapter_spike.schema.json" },
    "generationHealthChecker": { "$ref": "generation_health_checker.schema.json" },
    "promptConflictChecker": { "$ref": "prompt_conflict_checker.schema.json" },
    "storyChanges": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transactions", "reflowReports", "pendingConfirmationCount", "lastGeneratedAt"],
      "properties": {
        "transactions": {
          "type": "array",
          "items": { "$ref": "story_change_transaction.schema.json" }
        },
        "reflowReports": {
          "type": "array",
          "items": { "$ref": "reflow_impact_report.schema.json" }
        },
        "pendingConfirmationCount": { "type": "integer", "minimum": 0 },
        "lastGeneratedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config", "detectionReport", "providerEnablementSummary"],
      "properties": {
        "config": { "$ref": "runtime_config.schema.json" },
        "detectionReport": { "$ref": "tool_detection_report.schema.json" },
        "providerEnablementSummary": { "$ref": "provider_enablement.schema.json#/$defs/providerEnablementSummary" }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": true,
      "required": ["issues", "generatedBy"],
      "properties": {
        "issues": { "type": "array", "items": { "type": "object" } },
        "schemaSummary": { "type": "object" },
        "generatedBy": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
      }
    },
    "knowledge": {
      "type": "object",
      "additionalProperties": true,
      "required": ["packCount", "enabledCount", "categories", "manifestHash", "manifestVersion", "validationIssues", "bindings"],
      "properties": {
        "packCount": { "type": "integer", "minimum": 0 },
        "enabledCount": { "type": "integer", "minimum": 0 },
        "categories": { "type": "array", "items": { "type": "object" } },
        "manifestHash": { "type": "string" },
        "manifestVersion": { "type": "string" },
        "validationIssues": { "type": "array", "items": { "type": "string" } },
        "bindings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["packId", "version", "hash", "category", "title", "summary", "tags", "enabled", "maxInjectionTokens"],
            "properties": {
              "packId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "version": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "hash": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "category": { "$ref": "common.schema.json#/$defs/knowledgePackCategory" },
              "title": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
              "summary": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" } },
              "enabled": { "type": "boolean" },
              "maxInjectionTokens": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "stateSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label"],
      "properties": {
        "kind": { "type": "string", "enum": ["runtime-state", "runtime-audit-fallback", "fallback-audit"] },
        "label": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "path": { "type": "string" },
        "sourceAuditPath": { "type": "string" },
        "sourceImportedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
        "note": { "type": "string" }
      }
    },
    "legacyAudit": {
      "type": "object",
      "description": "Optional debug-only legacy snapshot. UI state must be rebuilt from the first-class ProjectRuntimeState fields."
    }
  }
}

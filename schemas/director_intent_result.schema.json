{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/director_intent_result.schema.json",
  "title": "DirectorIntentResult",
  "description": "Conservative structured classification of director natural-language intent before any project mutation or prompt change.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "userIntent",
    "normalizedIntent",
    "intentType",
    "operation",
    "impactScope",
    "targetIds",
    "confidence",
    "requiresUserConfirmation",
    "confirmationReasons",
    "riskFlags",
    "detectedKeywords",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "userIntent": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "normalizedIntent": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "intentType": {
      "type": "string",
      "enum": ["story", "shot", "asset", "style", "voice", "export", "unknown"]
    },
    "operation": {
      "type": "string",
      "enum": [
        "insert_shot",
        "delete_shot",
        "move_shot",
        "update_story",
        "update_shot",
        "update_character",
        "update_scene",
        "update_style",
        "update_dialogue",
        "update_narration",
        "update_voice",
        "lock_asset",
        "unlock_asset",
        "export_change",
        "unknown"
      ]
    },
    "impactScope": {
      "type": "string",
      "enum": ["project", "section", "shot", "asset", "voice", "export"]
    },
    "targetIds": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "requiresUserConfirmation": { "type": "boolean" },
    "confirmationReasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "riskFlags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "detectedKeywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "createdAt": { "$ref": "common.schema.json#/$defs/isoDateTime" }
  }
}

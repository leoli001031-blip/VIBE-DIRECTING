{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/real_execution_gate.schema.json",
  "title": "RealExecutionGateState",
  "description": "Scoped real-test execution gate. It permits only selected project, batch, and shot review evidence while actual worker spawn, provider submit, credential access, and file mutation remain locked.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "phase",
    "mode",
    "status",
    "projectId",
    "selectedShotIds",
    "selectedTaskPlanIds",
    "selectedEnvelopeIds",
    "outputSandbox",
    "items",
    "summary",
    "hardLocks",
    "forbiddenActions",
    "notes"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "generatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "phase": { "const": "scoped_real_execution_gate" },
    "mode": { "$ref": "#/$defs/mode" },
    "status": { "$ref": "#/$defs/status" },
    "projectId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "batchId": { "type": "string" },
    "selectedShotIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "selectedTaskPlanIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "selectedEnvelopeIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "outputSandbox": { "$ref": "execution_ledger.schema.json#/$defs/outputSandbox" },
    "items": { "type": "array", "items": { "$ref": "#/$defs/item" } },
    "summary": { "$ref": "#/$defs/summary" },
    "hardLocks": { "$ref": "#/$defs/hardLocks" },
    "forbiddenActions": {
      "type": "array",
      "items": { "$ref": "#/$defs/forbiddenAction" },
      "uniqueItems": true
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "mode": {
      "type": "string",
      "enum": ["locked", "scoped_real_test"]
    },
    "status": {
      "type": "string",
      "enum": ["locked", "blocked", "ready_for_scoped_real_test_review"]
    },
    "checkId": {
      "type": "string",
      "enum": [
        "selected_project",
        "selected_batch",
        "selected_shot",
        "validated_envelope",
        "output_sandbox",
        "manifest_ready",
        "qa_ready",
        "ledger_ready",
        "provider_routes_closed",
        "worker_spawn_closed",
        "credential_routes_closed"
      ]
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["checkId", "label", "required", "passed"],
      "properties": {
        "checkId": { "$ref": "#/$defs/checkId" },
        "label": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "required": { "const": true },
        "passed": { "type": "boolean" },
        "blocker": { "type": "string" },
        "sourceRef": { "type": "string" }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gateItemId",
        "projectId",
        "taskPlanId",
        "jobId",
        "providerId",
        "providerSlot",
        "requiredMode",
        "expectedOutputs",
        "outputSandboxRoot",
        "status",
        "checks",
        "blockers",
        "warnings",
        "canEnterScopedRealTestMode",
        "scopedRealTestReviewOnly",
        "actualExecutionAllowed",
        "canExecute",
        "canSpawnWorker",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "noWorkerSpawn",
        "noProviderSubmit",
        "noCredentialRead",
        "noFileMutation"
      ],
      "properties": {
        "gateItemId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "projectId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "batchId": { "type": "string" },
        "shotId": { "type": "string" },
        "taskPlanId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "jobId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "envelopeId": { "type": "string" },
        "providerId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "providerSlot": { "$ref": "common.schema.json#/$defs/providerSlot" },
        "requiredMode": { "$ref": "common.schema.json#/$defs/requiredMode" },
        "expectedOutputs": { "type": "array", "items": { "type": "string" } },
        "outputSandboxRoot": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "ledgerEntryId": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "checks": { "type": "array", "items": { "$ref": "#/$defs/check" } },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "canEnterScopedRealTestMode": { "type": "boolean" },
        "scopedRealTestReviewOnly": { "const": true },
        "actualExecutionAllowed": { "const": false },
        "canExecute": { "const": false },
        "canSpawnWorker": { "const": false },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "noWorkerSpawn": { "const": true },
        "noProviderSubmit": { "const": true },
        "noCredentialRead": { "const": true },
        "noFileMutation": { "const": true }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalItems",
        "locked",
        "blocked",
        "readyForScopedRealTestReview",
        "canEnterScopedRealTestMode",
        "actualExecutionAllowed",
        "canExecute",
        "workerSpawnsAllowed",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed"
      ],
      "properties": {
        "totalItems": { "type": "integer", "minimum": 0 },
        "locked": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "readyForScopedRealTestReview": { "type": "integer", "minimum": 0 },
        "canEnterScopedRealTestMode": { "type": "integer", "minimum": 0 },
        "actualExecutionAllowed": { "const": false },
        "canExecute": { "const": false },
        "workerSpawnsAllowed": { "type": "integer", "const": 0 },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false }
      }
    },
    "hardLocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultLocked",
        "scopedRealTestReviewOnly",
        "actualExecutionAllowed",
        "canExecute",
        "canSpawnWorker",
        "noWorkerSpawn",
        "noSubprocess",
        "noShellExecution",
        "providerSubmissionForbidden",
        "noProviderSubmit",
        "canSubmitProvider",
        "providerSubmitAllowed",
        "liveSubmitAllowed",
        "credentialAccessAllowed",
        "noCredentialRead",
        "noCredentialWrite",
        "noFileMutation",
        "selectedScopeRequired",
        "validatedEnvelopeRequired",
        "outputSandboxRequired",
        "manifestRequired",
        "qaRequired",
        "ledgerRequired"
      ],
      "properties": {
        "defaultLocked": { "const": true },
        "scopedRealTestReviewOnly": { "const": true },
        "actualExecutionAllowed": { "const": false },
        "canExecute": { "const": false },
        "canSpawnWorker": { "const": false },
        "noWorkerSpawn": { "const": true },
        "noSubprocess": { "const": true },
        "noShellExecution": { "const": true },
        "providerSubmissionForbidden": { "const": true },
        "noProviderSubmit": { "const": true },
        "canSubmitProvider": { "const": false },
        "providerSubmitAllowed": { "type": "integer", "const": 0 },
        "liveSubmitAllowed": { "const": false },
        "credentialAccessAllowed": { "const": false },
        "noCredentialRead": { "const": true },
        "noCredentialWrite": { "const": true },
        "noFileMutation": { "const": true },
        "selectedScopeRequired": { "const": true },
        "validatedEnvelopeRequired": { "const": true },
        "outputSandboxRequired": { "const": true },
        "manifestRequired": { "const": true },
        "qaRequired": { "const": true },
        "ledgerRequired": { "const": true }
      }
    },
    "forbiddenAction": {
      "type": "string",
      "enum": [
        "unscoped_project",
        "unscoped_batch",
        "unscoped_shot",
        "unvalidated_envelope",
        "output_path_outside_sandbox",
        "missing_manifest",
        "missing_qa",
        "missing_ledger",
        "worker_spawn",
        "subprocess",
        "shell_execution",
        "provider_submit",
        "credential_read",
        "credential_write",
        "file_mutation"
      ]
    }
  }
}

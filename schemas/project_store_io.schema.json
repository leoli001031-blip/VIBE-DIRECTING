{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/project_store_io.schema.json",
  "title": "ProjectStoreIoGate",
  "description": "Phase 19 real Project Store IO gate for project-root-whitelisted project.vibe create/open/save and runtime cache rebuild without provider, credential, arbitrary shell, delete, or user-file move routes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "phase",
    "mode",
    "generatedAt",
    "rootRef",
    "fileMutationScope",
    "projectVibeWriteAllowed",
    "runtimeStateWriteAllowed",
    "directoryCreateAllowed",
    "canExecute",
    "snapshotValidation",
    "projectFileFactSource",
    "entries",
    "whitelist",
    "blockers",
    "warnings",
    "hardLocks",
    "notes"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "phase": { "type": "string", "const": "phase19_real_project_store_io_gate" },
    "mode": { "type": "string", "enum": ["create", "open", "save", "rebuild_cache"] },
    "generatedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" },
    "rootRef": { "type": "string", "const": "project_root" },
    "fileMutationScope": { "type": "string", "const": "project_root_whitelist" },
    "projectVibeWriteAllowed": { "type": "boolean" },
    "runtimeStateWriteAllowed": { "type": "boolean" },
    "directoryCreateAllowed": { "type": "boolean" },
    "canExecute": { "type": "boolean" },
    "snapshotValidation": { "type": "object" },
    "projectFileFactSource": { "$ref": "#/$defs/projectFileFactSource" },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/ioEntry" }
    },
    "whitelist": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?![A-Za-z]:[\\\\/])(?!/)(?!//)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
      }
    },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "hardLocks": { "$ref": "#/$defs/hardLocks" },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "ioEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "operation", "path", "canExecute", "projectRootRelative", "notes"],
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "role": {
          "type": "string",
          "enum": [
            "project_manifest",
            "production_bible",
            "story_flow",
            "visual_memory",
            "shot_spec",
            "shot_layout",
            "spatial_memory",
            "scene_asset_pack",
            "voice_memory",
            "source_index",
            "runtime_state",
            "project_directory"
          ]
        },
        "operation": { "type": "string", "enum": ["create_directory", "read_file", "write_file"] },
        "path": {
          "type": "string",
          "pattern": "^(?![A-Za-z]:[\\\\/])(?!/)(?!//)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
        },
        "content": { "type": "string" },
        "contentHash": { "type": "string" },
        "canExecute": { "type": "boolean" },
        "projectRootRelative": { "type": "boolean", "const": true },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "projectFileFactSource": {
      "type": "object",
      "additionalProperties": true,
      "required": ["receiptKind", "projectVibeEntry", "saveOpenContract", "runtimeStateDerivedCache", "projectLocalKnowledgeScope", "blockedAuthoritySources"],
      "properties": {
        "receiptKind": { "type": "string", "const": "project_file_fact_source" },
        "projectVibeEntry": {
          "type": "object",
          "additionalProperties": true,
          "required": ["path", "sourceOfTruth", "runtimeStateMayOverride"],
          "properties": {
            "path": { "type": "string", "const": "project.vibe" },
            "sourceOfTruth": { "type": "string", "const": "project_file" },
            "runtimeStateMayOverride": { "type": "boolean", "const": false }
          }
        },
        "saveOpenContract": {
          "type": "object",
          "additionalProperties": true,
          "required": ["projectRootRelativeRequired", "absolutePathsBlocked", "parentTraversalBlocked", "userFileMoveDeleteBlocked", "credentialTokenSecretWriteBlocked"],
          "properties": {
            "projectRootRelativeRequired": { "type": "boolean", "const": true },
            "absolutePathsBlocked": { "type": "boolean", "const": true },
            "parentTraversalBlocked": { "type": "boolean", "const": true },
            "userFileMoveDeleteBlocked": { "type": "boolean", "const": true },
            "credentialTokenSecretWriteBlocked": { "type": "boolean", "const": true }
          }
        },
        "runtimeStateDerivedCache": {
          "type": "object",
          "additionalProperties": true,
          "required": ["path", "sourceOfTruth", "mayBeRebuilt", "mayOverwriteProjectFiles"],
          "properties": {
            "path": { "type": "string", "const": "runtime-state.json" },
            "sourceOfTruth": { "type": "string", "const": "derived_cache" },
            "mayBeRebuilt": { "type": "boolean", "const": true },
            "mayOverwriteProjectFiles": { "type": "boolean", "const": false }
          }
        },
        "projectLocalKnowledgeScope": {
          "type": "object",
          "additionalProperties": true,
          "required": ["projectKnowledgeMayBeFactReference", "globalKnowledgeMayAuthorizeProjectFacts", "oldChatMayAuthorizeProjectFacts", "directInputMayAuthorizeProjectFacts"],
          "properties": {
            "projectKnowledgeMayBeFactReference": { "type": "boolean", "const": true },
            "globalKnowledgeMayAuthorizeProjectFacts": { "type": "boolean", "const": false },
            "oldChatMayAuthorizeProjectFacts": { "type": "boolean", "const": false },
            "directInputMayAuthorizeProjectFacts": { "type": "boolean", "const": false }
          }
        },
        "blockedAuthoritySources": {
          "type": "array",
          "contains": { "type": "string", "const": "runtime_state" },
          "items": { "type": "string" }
        }
      }
    },
    "hardLocks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectRootOnly",
        "whitelistOnly",
        "noAbsoluteContractPath",
        "noParentTraversal",
        "noUserFileMove",
        "noDelete",
        "noProviderSubmit",
        "noImageGeneration",
        "noVideoGeneration",
        "noCredentialRead",
        "noCredentialWrite",
        "noArbitraryShell",
        "runtimeStateIsDerivedCache"
      ],
      "properties": {
        "projectRootOnly": { "type": "boolean", "const": true },
        "whitelistOnly": { "type": "boolean", "const": true },
        "noAbsoluteContractPath": { "type": "boolean", "const": true },
        "noParentTraversal": { "type": "boolean", "const": true },
        "noUserFileMove": { "type": "boolean", "const": true },
        "noDelete": { "type": "boolean", "const": true },
        "noProviderSubmit": { "type": "boolean", "const": true },
        "noImageGeneration": { "type": "boolean", "const": true },
        "noVideoGeneration": { "type": "boolean", "const": true },
        "noCredentialRead": { "type": "boolean", "const": true },
        "noCredentialWrite": { "type": "boolean", "const": true },
        "noArbitraryShell": { "type": "boolean", "const": true },
        "runtimeStateIsDerivedCache": { "type": "boolean", "const": true }
      }
    }
  }
}

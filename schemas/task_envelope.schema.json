{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/task_envelope.schema.json",
  "title": "TaskEnvelope",
  "description": "The execution contract for one provider or worker task. Preflight is mandatory.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "purpose",
    "providerSlot",
    "providerId",
    "executionState",
    "requiredMode",
    "sourceIndexHash",
    "dependencies",
    "contextLevel",
    "expectedOutputs",
    "hardRules",
    "references",
    "qaChecklist",
    "preflight",
    "injectedKnowledgePacks",
    "injectedKnowledgeSnippetIds",
    "injectedKnowledgeSnippets",
    "routeWarnings",
    "blockingReasons"
  ],
  "properties": {
    "schemaVersion": { "$ref": "common.schema.json#/$defs/schemaVersion" },
    "id": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "purpose": {
      "type": "string",
      "enum": ["asset", "keyframe", "video", "audit", "unknown"]
    },
    "providerSlot": { "$ref": "common.schema.json#/$defs/providerSlot" },
    "providerId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "executionState": { "$ref": "common.schema.json#/$defs/providerExecutionState" },
    "requiredMode": { "$ref": "common.schema.json#/$defs/requiredMode" },
    "providerRequirements": { "$ref": "#/$defs/providerCapabilityRequirement" },
    "storyFunction": { "type": "string" },
    "sourceIndexHash": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "promptHash": { "type": "string" },
    "dependencies": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
    },
    "contextLevel": { "$ref": "common.schema.json#/$defs/contextLevel" },
    "expectedOutputs": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
    },
    "hardRules": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "minItems": 1
    },
    "references": {
      "type": "array",
      "items": { "$ref": "reference_authority.schema.json" }
    },
    "qaChecklist": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
      "minItems": 1
    },
    "preflight": { "$ref": "preflight_report.schema.json" },
    "keyframePairDerivation": { "$ref": "keyframe_pair_derivation.schema.json" },
    "knowledgeRouteResultId": { "type": "string" },
    "contextBudgetId": { "type": "string" },
    "injectedKnowledgePacks": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/knowledgeInjectionRecord" }
    },
    "injectedKnowledgeSnippetIds": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/nonEmptyString" }
    },
    "injectedKnowledgeSnippets": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/knowledgeInjectedSnippet" }
    },
    "knowledgeInputHash": { "type": "string" },
    "knowledgeManifestHash": { "type": "string" },
    "policyBinding": { "type": "string" },
    "routeWarnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nonOverridableGateHashes": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "promptPlanId": { "type": "string" },
    "promptPlanHash": { "type": "string" },
    "sourceShotSpecHash": { "type": "string" },
    "outputPath": { "type": "string" },
    "blockingReasons": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "providerSlot": { "const": "video.i2v" }
        },
        "required": ["providerSlot"]
      },
      "then": {
        "required": ["keyframePairDerivation"]
      }
    }
  ],
  "$defs": {
    "providerCapabilityRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "requiredMode", "inputKinds", "outputKind", "notes"],
      "properties": {
        "slot": { "$ref": "common.schema.json#/$defs/providerSlot" },
        "requiredMode": { "$ref": "common.schema.json#/$defs/requiredMode" },
        "inputKinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["text", "image", "reference_image", "mask", "start_frame", "end_frame", "video"]
          }
        },
        "outputKind": {
          "type": "string",
          "enum": ["image", "video", "audio", "metadata"]
        },
        "supports": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "referenceImage": { "type": "boolean" },
            "imageEdit": { "type": "boolean" },
            "startEndFrame": { "type": "boolean" },
            "bbox": { "type": "string", "enum": ["supported", "unsupported", "planned", "parked"] },
            "cameraControl": { "type": "string", "enum": ["none", "textual", "structured", "planned"] },
            "controlNet": { "type": "string", "enum": ["supported", "unsupported", "planned", "parked"] },
            "mask": { "type": "string", "enum": ["supported", "unsupported", "planned", "parked"] },
            "negativePrompt": { "type": "string", "enum": ["supported", "unsupported", "planned", "parked"] }
          }
        },
        "maxReferenceImages": { "type": "integer", "minimum": 0 },
        "forbiddenFallbacks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "executionStates": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/$defs/providerExecutionState" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibecore.local/schemas/asset_readiness_report.schema.json",
  "title": "AssetReadinessReport",
  "description": "Shot-level reference readiness gate for draft/formal image pipeline use.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reportId",
    "shotId",
    "assetIds",
    "status",
    "formalBlocked",
    "gates",
    "blockers",
    "warnings",
    "safeReferenceIds",
    "unsafeReferenceIds",
    "lockedReferenceIds",
    "candidateReferenceIds",
    "missingReferenceIds",
    "rejectedReferenceIds",
    "tempReferenceIds",
    "failedReferenceIds",
    "checkedAt"
  ],
  "properties": {
    "reportId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "shotId": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
    "assetIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": {
      "type": "string",
      "enum": ["ready", "draft_only", "blocked"]
    },
    "formalBlocked": { "type": "boolean" },
    "gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/readinessGate" },
      "allOf": [
        { "contains": { "type": "object", "properties": { "gateId": { "const": "identity_gate" } }, "required": ["gateId"] } },
        { "contains": { "type": "object", "properties": { "gateId": { "const": "scene_gate" } }, "required": ["gateId"] } },
        { "contains": { "type": "object", "properties": { "gateId": { "const": "pair_gate" } }, "required": ["gateId"] } },
        { "contains": { "type": "object", "properties": { "gateId": { "const": "story_gate" } }, "required": ["gateId"] } },
        { "contains": { "type": "object", "properties": { "gateId": { "const": "prop_gate" } }, "required": ["gateId"] } },
        { "contains": { "type": "object", "properties": { "gateId": { "const": "style_gate" } }, "required": ["gateId"] } }
      ]
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "safeReferenceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unsafeReferenceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lockedReferenceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "candidateReferenceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missingReferenceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rejectedReferenceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tempReferenceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failedReferenceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checkedAt": { "$ref": "common.schema.json#/$defs/isoDateTime" }
  },
  "$defs": {
    "readinessGate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gateId", "status", "requiredForFormal", "detail", "sourceRefs", "blockers", "warnings"],
      "properties": {
        "gateId": {
          "type": "string",
          "enum": ["identity_gate", "scene_gate", "pair_gate", "story_gate", "prop_gate", "style_gate"]
        },
        "status": { "type": "string", "enum": ["pass", "warning", "blocked"] },
        "requiredForFormal": { "type": "boolean" },
        "detail": { "$ref": "common.schema.json#/$defs/nonEmptyString" },
        "sourceRefs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "formalBlocked": { "const": true }
        },
        "required": ["formalBlocked"]
      },
      "then": {
        "properties": {
          "status": {
            "type": "string",
            "enum": ["draft_only", "blocked"]
          }
        }
      }
    }
  ]
}
